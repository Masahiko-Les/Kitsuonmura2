rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isNotBanned() {
      return signedIn() && !exists(/databases/$(database)/documents/bannedUsers/$(request.auth.uid));
    }

    function postKeysAreValidOnCreate() {
      return request.resource.data.keys().hasOnly([
        'text',
        'authorUid',
        'authorNickname',
        'createdAt',
        'createdAtMs',
        'isHidden',
        'likeCount',
        'reportCount',
      ]);
    }

    function postCreateIsValid() {
      return postKeysAreValidOnCreate()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.authorNickname is string
        && request.resource.data.authorNickname.size() > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAtMs is int
        && request.resource.data.createdAtMs > 0
        && request.resource.data.isHidden == false
        && request.resource.data.likeCount == 0
        && request.resource.data.reportCount == 0;
    }

    function postImmutableFieldsUnchanged() {
      return request.resource.data.text == resource.data.text
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.authorNickname == resource.data.authorNickname
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdAtMs == resource.data.createdAtMs;
    }

    function postCountersAreNonNegative() {
      return (
        !request.resource.data.keys().hasAny(['likeCount'])
          || (request.resource.data.likeCount is int && request.resource.data.likeCount >= 0)
      )
        && (
          !request.resource.data.keys().hasAny(['reportCount'])
            || (request.resource.data.reportCount is int && request.resource.data.reportCount >= 0)
        );
    }

    function likeDocPath(postId) {
      return /databases/$(database)/documents/posts/$(postId)/likes/$(request.auth.uid);
    }

    function reportDocPath(postId) {
      return /databases/$(database)/documents/posts/$(postId)/reports/$(request.auth.uid);
    }

    function likeToggleUpdate(postId) {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      let beforeExists = exists(likeDocPath(postId));
      let afterExists = existsAfter(likeDocPath(postId));
      let currentLikeCount = resource.data.likeCount is int ? resource.data.likeCount : 0;
      
      // Safely compare optional fields - permit if both missing or both present and equal
      let reportCountOk = (
        !resource.data.keys().hasAny(['reportCount']) && !request.resource.data.keys().hasAny(['reportCount'])
      ) || (request.resource.data.reportCount == resource.data.reportCount);
      
      let isHiddenOk = (
        !resource.data.keys().hasAny(['isHidden']) && !request.resource.data.keys().hasAny(['isHidden'])
      ) || (request.resource.data.isHidden == resource.data.isHidden);
      
      let hiddenAtOk = (
        !resource.data.keys().hasAny(['hiddenAt']) && !request.resource.data.keys().hasAny(['hiddenAt'])
      ) || (request.resource.data.hiddenAt == resource.data.hiddenAt);
      
      let hiddenReasonOk = (
        !resource.data.keys().hasAny(['hiddenReason']) && !request.resource.data.keys().hasAny(['hiddenReason'])
      ) || (request.resource.data.hiddenReason == resource.data.hiddenReason);
      
      return keys.hasOnly(['likeCount'])
        && postImmutableFieldsUnchanged()
        && reportCountOk
        && isHiddenOk
        && hiddenAtOk
        && hiddenReasonOk
        && postCountersAreNonNegative()
        && beforeExists != afterExists
        && (
          (afterExists && request.resource.data.likeCount == currentLikeCount + 1)
          || (!afterExists && request.resource.data.likeCount == currentLikeCount - 1)
        );
    }

    function reportToggleUpdate(postId) {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      let beforeExists = exists(reportDocPath(postId));
      let afterExists = existsAfter(reportDocPath(postId));
      let currentReportCount = resource.data.reportCount is int ? resource.data.reportCount : 0;
      let reportDeltaOk = (
        (afterExists && request.resource.data.reportCount == currentReportCount + 1)
        || (!afterExists && request.resource.data.reportCount == currentReportCount - 1)
      );
      
      // For old posts without hiddenAt/hiddenReason fields, allow unchanged (both missing)
      let hiddenFieldsUnchanged = (
        (
          !resource.data.keys().hasAny(['isHidden']) && !request.resource.data.keys().hasAny(['isHidden'])
          || request.resource.data.isHidden == resource.data.isHidden
        )
        && (
          !resource.data.keys().hasAny(['hiddenAt']) && !request.resource.data.keys().hasAny(['hiddenAt'])
          || request.resource.data.hiddenAt == resource.data.hiddenAt
        )
        && (
          !resource.data.keys().hasAny(['hiddenReason']) && !request.resource.data.keys().hasAny(['hiddenReason'])
          || request.resource.data.hiddenReason == resource.data.hiddenReason
        )
      );
      
      // New posts can transition to hidden at report threshold
      let hiddenByThreshold = request.resource.data.reportCount >= 3
        && request.resource.data.isHidden == true
        && request.resource.data.hiddenAt is timestamp
        && request.resource.data.hiddenReason is string;
      
      return keys.hasOnly(['reportCount', 'isHidden', 'hiddenAt', 'hiddenReason'])
        && postImmutableFieldsUnchanged()
        && request.resource.data.likeCount == resource.data.likeCount
        && postCountersAreNonNegative()
        && beforeExists != afterExists
        && reportDeltaOk
        && (hiddenFieldsUnchanged || hiddenByThreshold);
    }

    function ownerHideUpdate() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return request.auth.uid == resource.data.authorUid
        && keys.hasOnly(['isHidden', 'hiddenAt', 'hiddenReason'])
        && postImmutableFieldsUnchanged()
        && request.resource.data.likeCount == resource.data.likeCount
        && request.resource.data.reportCount == resource.data.reportCount
        && request.resource.data.isHidden == true
        && request.resource.data.hiddenReason is string
        && request.resource.data.hiddenAt is timestamp;
    }

    function userDocWriteIsValid(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /posts/{postId} {
      allow get: if signedIn() && resource.data.isHidden != true;
      allow list: if signedIn();
      allow create: if isNotBanned() && postCreateIsValid();
      allow update: if isNotBanned()
        && (likeToggleUpdate(postId) || reportToggleUpdate(postId) || ownerHideUpdate());
      allow delete: if false;

      match /likes/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if isNotBanned()
          && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.createdAt is timestamp;
        allow update: if false;
        allow delete: if isNotBanned() && request.auth.uid == uid;
      }

      match /reports/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if isNotBanned()
          && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'reason', 'createdAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.reason is string
          && request.resource.data.createdAt is timestamp;
        allow update: if false;
        allow delete: if isNotBanned() && request.auth.uid == uid;
      }
    }

    match /users/{uid} {
      allow read, create, update, delete: if userDocWriteIsValid(uid);

      match /hiddenPosts/{postId} {
        allow read, create, update, delete: if isNotBanned() && request.auth.uid == uid;
      }

      match /blockedUsers/{blockedUid} {
        allow read, create, update, delete: if isNotBanned() && request.auth.uid == uid;
      }
    }

    match /bannedUsers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}